# AXLE (Axiom Lean Engine) API Configuration

# API key for authentication
# AXLE_API_KEY=your-api-key

# API endpoint URL
AXLE_API_URL=https://axle.axiommath.ai

# Base timeout in seconds for retry window if service is temporarily unavailable (default: 1_800 = 30 minutes)
# AXLE_TIMEOUT_SECONDS=1_800

# Max concurrent requests (default: 20)
# AXLE_MAX_CONCURRENCY=20
